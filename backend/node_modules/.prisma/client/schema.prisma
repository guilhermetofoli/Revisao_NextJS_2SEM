// schema.prisma — define a estrutura do banco de dados
// O Prisma usa este arquivo para gerar as migrations e o client tipado

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  // Chave primária com UUID gerado automaticamente
  id String @id @default(uuid())

  // Dados do usuário
  nome     String
  email    String @unique // UNIQUE: não permite e-mails duplicados
  senha    String // Armazenada já criptografada com bcrypt
  endereco String

  // Campos de controle de auditoria (gerenciados automaticamente pelo Prisma)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft Delete: quando preenchido, o usuário é considerado "deletado"
  // Aceita null (usuário ativo) ou uma data (usuário deletado)
  deletedAt DateTime?

  @@map("users") // nome da tabela no banco será "users"
}
